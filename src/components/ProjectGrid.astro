---
// src/components/ProjectGrid.astro
import type { CollectionEntry } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

type ProjectEntry = CollectionEntry<"projects">;

const {
  projects = [],
  variant = "grid",
  ariaLabel = "Project list",
} = Astro.props as {
  projects?: ProjectEntry[];
  variant?: "grid" | "reel";
  ariaLabel?: string;
};

const isReel = variant === "reel";
---

<section
  class:list={["project-grid", "grid", isReel && "project-grid--reel"]}
  aria-label={ariaLabel}
  data-project-grid={variant}
>
  {projects.filter(Boolean).map((entry: ProjectEntry) => (
    <ProjectCard project={entry} />
  ))}
</section>

<style>
  /* Default: grid */
  .project-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 880px) {
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Reel variant: horizontal scroll-snap rail (carousel vibe, no autoplay) */
  .project-grid--reel {
    grid-template-columns: none;
    grid-auto-flow: column;
    grid-auto-columns: minmax(18rem, 28%);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-3);
    gap: var(--space-4);
  }

  .project-grid--reel > * {
    scroll-snap-align: start;
  }

  @media (max-width: 980px) {
    .project-grid--reel {
      grid-auto-columns: minmax(18rem, 42%);
    }
  }

  @media (max-width: 640px) {
    .project-grid--reel {
      grid-auto-columns: minmax(18rem, 86%);
    }
  }
</style>