---
// src/components/Footer.astro
import WhatsAppButton from "./WhatsAppButton.astro";

const currentYear = new Date().getFullYear();

const pathname = Astro.url?.pathname ?? "/";
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
};

const quickLinks: { href: string; label: string }[] = [
  { href: "/services", label: "Services" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const legalLinks: { href: string; label: string }[] = [
  { href: "/privacy", label: "Privacy Policy" },
  { href: "/terms", label: "Terms of Service" },
];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__grid">
      <!-- Brand -->
      <div class="site-footer__brand">
        <a href="/" class="site-footer__brand-link" aria-label="Fini's Kitchens home">
          <span class="site-footer__mark" aria-hidden="true">
            <img
              class="site-footer__logo-img"
              src="/images/finis-kitchens-icon-64.png"
              srcset="/images/finis-kitchens-icon-64.png 1x, /images/finis-kitchens-icon-128.png 2x"
              alt=""
              width="28"
              height="28"
              decoding="async"
            />
          </span>

          <span class="site-footer__brand-text">
            <span class="site-footer__name">Fini's Kitchens</span>
            <span class="site-footer__tagline">Thoughtful kitchens for real homes</span>
          </span>
        </a>

        <p class="site-footer__blurb">
          Kitchen design & installation around Horsham - from first sketch to that first cup of tea.
        </p>
      </div>

      <!-- Quick links -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Showroom location</h3>

        <address class="site-footer__text">
          <a
            class="site-footer__link"
            href="https://www.google.com/maps/search/?api=1&query=Laughton%20Rd%2C%20Ringmer%2C%20Lewes%20BN8%205SY"
            target="_blank"
            rel="noopener noreferrer"
          >
            Laughton Rd, Ringmer<br />
            Lewes BN8 5SY
          </a>
        </address>

        <div class="site-footer__actions">
          <a
            class="site-footer__link"
            href="https://www.google.com/maps/search/?api=1&query=Laughton%20Rd%2C%20Ringmer%2C%20Lewes%20BN8%205SY"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span aria-hidden="true">↗</span> Open in Maps
          </a>

          <a
            class="site-footer__link"
            href="https://www.google.com/maps/dir/?api=1&destination=Laughton%20Rd%2C%20Ringmer%2C%20Lewes%20BN8%205SY"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span aria-hidden="true">↗</span> Get directions
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div class="site-footer__col">
        <h3 class="site-footer__heading">Contact</h3>
        <ul class="site-footer__list">
          <li class="site-footer__item">
            <a class="site-footer__link site-footer__link--icon" href="mailto:oli.wyatt@thefinigroup.co.uk">
              <span class="site-footer__ico" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-envelope" viewBox="0 0 16 16">
  <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/>
</svg>
              </span>
              oli.wyatt@thefinigroup.co.uk
            </a>
          </li>

          <li class="site-footer__item">
            <a class="site-footer__link site-footer__link--icon" href="tel:+447581390107">
              <span class="site-footer__ico" aria-hidden="true">
<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-telephone" viewBox="0 0 16 16">
  <path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.6 17.6 0 0 0 4.168 6.608 17.6 17.6 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.68.68 0 0 0-.58-.122l-2.19.547a1.75 1.75 0 0 1-1.657-.459L5.482 8.062a1.75 1.75 0 0 1-.46-1.657l.548-2.19a.68.68 0 0 0-.122-.58zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.68.68 0 0 0 .178.643l2.457 2.457a.68.68 0 0 0 .644.178l2.189-.547a1.75 1.75 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.6 18.6 0 0 1-7.01-4.42 18.6 18.6 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877z"/>
</svg>
              </span>
              +44 7581 390 107
            </a>
          </li>

          <li class="site-footer__item">
            <WhatsAppButton
              class="site-footer__link site-footer__link--icon"
              label="WhatsApp"
              text="Hi! I’d like to chat about a kitchen project."
            />
          </li>

          <li class="site-footer__item">
            <a
              class="site-footer__link site-footer__link--icon"
              href="https://www.instagram.com/finis_kitchens/"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="site-footer__ico" aria-hidden="true">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-instagram" viewBox="0 0 16 16">
  <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
</svg>
              </span>
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

      <div class="site-footer__bottom">
      <div class="container site-footer__bottom-inner">
        <span>© {currentYear} Fini's Kitchens. All rights reserved.</span>
        <span class="site-footer__meta">Company: 16193287</span>

        <a
          class="site-footer__studio"
          href="https://southcoastapps.co.uk"
          target="_blank"
          rel="noopener noreferrer"
        >
          Built by South Coast Apps.
        </a>

        <nav class="site-footer__legal" aria-label="Legal">
          {legalLinks.map((l, idx) => {
            const active = isActive(l.href);
            return (
              <>
                <a
                  href={l.href}
                  class:list={["site-footer__legal-link", active && "is-active"]}
                  aria-current={active ? "page" : undefined}
                >
                  {l.label}
                </a>
                {idx < legalLinks.length - 1 && <span aria-hidden="true">·</span>}
              </>
            );
          })}
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Premium = calm structure + consistent rhythm */
  .site-footer {
    margin-top: var(--space-11);

    /* Soft navy base + faint Fini-blue radial tint */
    background: #0e1a2a;
    background-image:
      radial-gradient(
        900px 520px at 14% 0%,
        rgba(142, 182, 220, 0.18) 0%,
        rgba(142, 182, 220, 0.10) 18%,
        rgba(142, 182, 220, 0.00) 60%
      ),
      radial-gradient(
        900px 520px at 110% 120%,
        rgba(0, 0, 0, 0.22) 0%,
        rgba(0, 0, 0, 0.00) 55%
      );

    color: #eaf0f7;
  }

  .site-footer p,
  .site-footer address {
    max-width: none;
  }

  .site-footer__inner {
    padding-block: var(--space-9);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) repeat(3, minmax(0, 1fr));
    gap: var(--space-8);
    align-items: start;
  }

  /* Brand */
  .site-footer__brand {
    display: grid;
    gap: var(--space-4);
    min-width: 0;
  }

  .site-footer__brand-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }
  .site-footer__actions {
    margin-top: var(--space-3);
    display: grid;
    gap: 0.15rem;
  }
  .site-footer__mark {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-pill);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(142, 182, 220, 0.14);
    border: 1px solid rgba(142, 182, 220, 0.22);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
    flex: 0 0 auto;
  }

  .site-footer__logo-img {
    width: 28px;
    height: 28px;
    display: block;
  }

  .site-footer__brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .site-footer__name {
    font-weight: 700;
    letter-spacing: 0.04em; /* less “techy” */
    text-transform: uppercase;
    font-size: 0.82rem;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .site-footer__tagline {
    color: rgba(234, 240, 247, 0.72);
    font-size: 0.95rem;
    line-height: 1.25;
  }

  .site-footer__blurb {
    margin: 0;
    color: rgba(234, 240, 247, 0.72);
    font-size: 0.95rem;
    line-height: var(--lh-base);
  }

  /* Columns */
  .site-footer__col {
    min-width: 0;
  }

  .site-footer__heading {
    margin: 0 0 var(--space-3);
    font-size: 0.9rem; /* sentence case */
    font-weight: 650;
    letter-spacing: 0.01em;
    color: rgba(234, 240, 247, 0.88);
  }

  .site-footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }

  .site-footer__item {
    margin: 0;
  }

  .site-footer__text {
    margin: 0;
    color: rgba(234, 240, 247, 0.72);
    line-height: var(--lh-base);
    font-style: normal;
  }

  .site-footer__hint {
    margin: var(--space-3) 0 0;
    font-size: 0.82rem;
    color: rgba(234, 240, 247, 0.58);
  }

  /* Links (single consistent style) */
  .site-footer__link {
    color: rgba(234, 240, 247, 0.82);
    text-decoration: none;
    border-radius: var(--radius-s);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.35rem 0; /* better tap target */
    white-space: nowrap; /* stops icon/text splitting */
    width: fit-content;
  }

  .site-footer__link--icon {
    display: inline-flex;        /* in case it's not already */
    align-items: center;
    gap: var(--space-2);
    line-height: 1;
  }
  .site-footer__ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.95;
    flex: 0 0 auto;
  }

  .site-footer__link:hover {
    color: #ffffff;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .site-footer__link:focus-visible {
    outline: 2px solid rgba(142, 182, 220, 0.65);
    outline-offset: 3px;
  }

  /* Active page: subtle underline (no pills) */
  .site-footer__link.is-active,
  .site-footer__link[aria-current="page"] {
    color: #ffffff;
    text-decoration: underline;
    text-decoration-color: rgba(142, 182, 220, 0.9);
    text-underline-offset: 0.22em;
  }

  /* Bottom bar */
  .site-footer__bottom {
    border-top: 1px solid rgba(234, 240, 247, 0.10);
  }

  .site-footer__bottom-inner {
    padding-block: var(--space-4);
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: var(--space-4);
    align-items: center;
    font-size: 0.78rem;
    color: rgba(234, 240, 247, 0.58);
  }

  .site-footer__meta {
    white-space: nowrap;
  }

  .site-footer__legal {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-self: end;
    white-space: nowrap;
  }

  .site-footer__legal-link {
    color: rgba(234, 240, 247, 0.72);
    text-decoration: none;
    padding: 0.2rem 0.25rem;
    border-radius: var(--radius-s);
  }

  .site-footer__legal-link:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .site-footer__legal-link:focus-visible {
    outline: 2px solid rgba(142, 182, 220, 0.65);
    outline-offset: 3px;
  }

  .site-footer__legal-link.is-active,
  .site-footer__legal-link[aria-current="page"] {
    color: #fff;
    text-decoration: underline;
    text-decoration-color: rgba(142, 182, 220, 0.9);
  }
  .site-footer__studio {
    color: rgba(234, 240, 247, 0.72);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.2rem 0.25rem;
    border-radius: var(--radius-s);
  }

  .site-footer__studio:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .site-footer__studio:focus-visible {
    outline: 2px solid rgba(142, 182, 220, 0.65);
    outline-offset: 3px;
  }
  /* Responsive */
  @media (max-width: 980px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__brand {
      grid-column: 1 / -1;
      padding-bottom: var(--space-5);
      border-bottom: 1px solid rgba(234, 240, 247, 0.10);
    }
  }

  @media (max-width: 560px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-7);
    }

    .site-footer__bottom-inner {
      grid-template-columns: 1fr;
      justify-items: start;
    }

    .site-footer__legal {
      justify-self: start;
    }

    /* Let long email wrap nicely on small screens */
    .site-footer__link {
      white-space: normal;
    }

    .site-footer__link--icon {
      align-items: center;
    }
  }
</style>