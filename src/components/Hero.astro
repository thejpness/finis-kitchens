---
import { Image } from "astro:assets";

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  imageSrc: ImageMetadata;  // Only ImageMetadata, no string
  imageAlt: string;
  imagePosition?: "left" | "right";
}

const { 
  title, 
  subtitle, 
  ctaText = "View all", 
  ctaLink = "#", 
  imageSrc, 
  imageAlt, 
  imagePosition = "right" 
} = Astro.props;
---

<section class="hero-section">
  <div class="hero-section__inner">
    <!-- content same as before -->
    <div class="hero-section__content">
      <h1 class="hero-section__title">{title}</h1>
      {subtitle && <p class="hero-section__subtitle">{subtitle}</p>}
      {ctaLink && (
        <a href={ctaLink} class="hero-section__cta btn btn--primary">
          {ctaText}
        </a>
      )}
    </div>
    
    <div class="hero-section__image">
      <Image
        src={imageSrc}
        alt={imageAlt}
        widths={[480, 768, 1024, 1280, 1600]}
        sizes="(max-width: 768px) 100vw, 45vw"
        loading="eager"
        width={800}
        height={600}
      />
    </div>
  </div>
</section>


<style>
  /* same styles as before */
  .hero-section {
    padding: 4rem 1.25rem 3rem;
  }

  .hero-section__inner {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-section__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-section__title {
    margin: 0;
    font-size: clamp(2rem, 3.5vw + 1rem, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero-section__subtitle {
    font-size: 1.1rem;
    color: #4b5563;
    line-height: 1.6;
    margin: 0;
  }

  .hero-section__cta {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .hero-section__image img {
    width: 100%;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.15);
  }

  @media (max-width: 880px) {
    .hero-section__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .hero-section__cta {
      align-self: center;
    }

    .hero-section {
      padding: 2.5rem 1.25rem;
    }
  }
</style>
