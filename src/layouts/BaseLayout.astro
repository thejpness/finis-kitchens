---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/components.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;   // can be absolute or site-relative like "/images/..."
  noindex?: boolean;
}

const {
  title = "Fini's Kitchens | Thoughtful Kitchen Design for Real Homes",
  description = "Fini's Kitchens designs and installs beautifully functional kitchens for real homes in and around Horsham.",
  ogImage = "/images/hero/default-hero.jpg",
  noindex = false,
} = Astro.props;

// Safe origin fallback if Astro.site isn't configured
const SITE_ORIGIN = (Astro.site?.toString() ?? "https://www.finiskitchens.co.uk").replace(/\/$/, "");

const toAbsoluteUrl = (pathOrUrl: string) => {
  try {
    // If already absolute, return as-is
    return new URL(pathOrUrl).toString();
  } catch {
    // Otherwise treat as site-relative
    return new URL(pathOrUrl, SITE_ORIGIN).toString();
  }
};

const canonicalURL = new URL(Astro.url.pathname, SITE_ORIGIN).toString();
const ogImageUrl = toAbsoluteUrl(ogImage);
---

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Theme hint (optional but nice) -->
    <meta name="theme-color" content="#f9fafb" />

    <!-- Preload primary font (if you added InterVariable.woff2) -->
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fini's Kitchens" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico?v=1" />
  </head>

  <body>
    <Header />
      <main id="main">
        <slot />
      </main>
    <Footer />
  </body>
</html>